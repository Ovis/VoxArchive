<Window x:Class="VoxArchive.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:domain="clr-namespace:VoxArchive.Domain;assembly=VoxArchive.Domain"
        Title="設定"
        Width="780"
        Height="700"
        MinWidth="780"
        MinHeight="700"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="#0A0D12"
        FontFamily="Yu Gothic UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#121821" />
        <SolidColorBrush x:Key="PanelBorder" Color="#283242" />
        <SolidColorBrush x:Key="ControlBg" Color="#1A2330" />
        <SolidColorBrush x:Key="ControlBorder" Color="#314055" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F3F6FA" />
        <SolidColorBrush x:Key="TextMuted" Color="#99A7BD" />
        <SolidColorBrush x:Key="Accent" Color="#E94545" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="Padding" Value="8,4" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#243A55" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A5EBD" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboBoxItemStyle}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" />
                            <Grid Margin="10,0,10,0" IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                                <TextBlock Grid.Column="1"
                                           Text="▼"
                                           FontSize="10"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Opacity="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="300"
                                        Background="{StaticResource ControlBg}"
                                        BorderBrush="{StaticResource ControlBorder}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboRoot" Property="BorderBrush" Value="#3D5D84" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboRoot" Property="Background" Value="#162131" />
                                <Setter TargetName="ComboRoot" Property="BorderBrush" Value="#25364C" />
                                <Setter Property="Foreground" Value="#7F8CA3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="#223042" />
            <Setter Property="BorderBrush" Value="#3A4E69" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="TitleBarGlyphButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#3A4A60" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D9E2F0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Base"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Base" Property="Background" Value="#1D2A3A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Base" Property="Background" Value="#16202D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#35506E" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Margin="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4B6B92" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Background" Value="#5B84B5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsScrollButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="#0E1724" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource SettingsScrollButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SettingsScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource SettingsScrollButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto" />
                                <Setter Property="Height" Value="12" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#10161F"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0"
                CornerRadius="10,10,0,0"
                MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
            <Grid Margin="10,0,6,0">
                <TextBlock Text="設定" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleBarGlyphButtonStyle}" Width="30"
                            Height="20"
                            Margin="0"
                            Padding="0"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Content="&#xE711;"
                            ToolTip="閉じる"
                            Click="OnTitleBarCloseButtonClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,14">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource SettingsScrollBarStyle}" />
                </ScrollViewer.Resources>
                <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="16,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="録音 / 文字起こし設定" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="マイク遅延補正" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="44" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OffsetTextBox" Grid.Column="0" ToolTip="マイク音声を前後にずらしてスピーカー音声とタイミングを合わせます" Margin="0,0,6,0" />
                                <Border Grid.Column="1" Height="36" Background="{StaticResource ControlBg}" BorderBrush="{StaticResource ControlBorder}" BorderThickness="1">
                                    <TextBlock Text="ms" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMuted}" Text="マイクの音が遅れるときに調整します（-1000～1000ms）。" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="既定 Speaker 再生ゲイン (dB)" />
                            <TextBox x:Name="DefaultSpeakerGainTextBox" />
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMuted}" Text="範囲: -60dB ～ 48dB" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="既定 Mic 再生ゲイン (dB)" />
                            <TextBox x:Name="DefaultMicGainTextBox" />
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMuted}" Text="範囲: -60dB ～ 48dB" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="録音開始/停止ショートカット" />
                        <TextBox x:Name="StartStopHotkeyTextBox"
                                 Grid.Row="1"
                                 Grid.Column="0"
                                 Margin="0,0,10,0"
                                 IsReadOnly="True"
                                 ToolTip="右のキー設定を押してから、登録したいキーを押してください（単体キー可）" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextMuted}"
                                   Text="キー設定を押して入力し、もう一度押して確定します。単体キーも指定可能です。" />
                        <Button x:Name="HotkeyCaptureButton"
                                Grid.Row="1"
                                Grid.Column="1"
                                Height="36"
                                Content="キー設定"
                                VerticalAlignment="Top"
                                Click="OnToggleHotkeyCaptureClick" />
                    </Grid>

                    <Grid Grid.Row="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="保存先フォルダ" />
                        <TextBox x:Name="OutputDirectoryTextBox" Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextMuted}"
                                   Text="録音ファイルの保存先フォルダを指定します。" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Height="36"
                                Content="参照"
                                VerticalAlignment="Top"
                                Click="OnBrowseOutputDirectoryClick" />
                    </Grid>

                    <Border Grid.Row="10" Background="#10161F" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <CheckBox x:Name="TranscriptionEnabledCheckBox" Content="文字起こし機能を有効化" />
                                <CheckBox x:Name="AutoTranscriptionCheckBox" Content="録音完了後に自動文字起こし" />
                                <CheckBox x:Name="ToastNotificationCheckBox" Content="完了時に通知を表示" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="実行モード" Margin="0,8,0,6" />
                                <ComboBox x:Name="ExecutionModeComboBox"
                                          Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=StackPanel}}"
                                          SelectedValuePath="Tag"
                                          SelectionChanged="OnTranscriptionEnvironmentSelectionChanged">
                                    <ComboBoxItem Content="自動" Tag="{x:Static domain:TranscriptionExecutionMode.Auto}" />
                                    <ComboBoxItem Content="CPU固定" Tag="{x:Static domain:TranscriptionExecutionMode.CpuOnly}" />
                                    <ComboBoxItem Content="CUDA優先" Tag="{x:Static domain:TranscriptionExecutionMode.CudaPreferred}" />
                                </ComboBox>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="モデル" Margin="0,8,0,6" />
                                <ComboBox x:Name="ModelComboBox"
                                          Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=StackPanel}}"
                                          SelectedValuePath="Tag"
                                          SelectionChanged="OnTranscriptionEnvironmentSelectionChanged">
                                    <ComboBoxItem Content="tiny" Tag="{x:Static domain:TranscriptionModel.Tiny}" />
                                    <ComboBoxItem Content="base" Tag="{x:Static domain:TranscriptionModel.Base}" />
                                    <ComboBoxItem Content="small" Tag="{x:Static domain:TranscriptionModel.Small}" />
                                    <ComboBoxItem Content="medium" Tag="{x:Static domain:TranscriptionModel.Medium}" />
                                    <ComboBoxItem Content="large-v3" Tag="{x:Static domain:TranscriptionModel.LargeV3}" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="言語" />
                                <ComboBox x:Name="LanguageComboBox"
                                          Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=StackPanel}}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="自動判定 (auto)" Tag="auto" />
                                    <ComboBoxItem Content="日本語 (ja)" Tag="ja" />
                                    <ComboBoxItem Content="英語 (en)" Tag="en" />
                                    <ComboBoxItem Content="中国語 (zh)" Tag="zh" />
                                    <ComboBoxItem Content="韓国語 (ko)" Tag="ko" />
                                    <ComboBoxItem Content="フランス語 (fr)" Tag="fr" />
                                    <ComboBoxItem Content="ドイツ語 (de)" Tag="de" />
                                    <ComboBoxItem Content="スペイン語 (es)" Tag="es" />
                                    <ComboBoxItem Content="イタリア語 (it)" Tag="it" />
                                    <ComboBoxItem Content="ポルトガル語 (pt)" Tag="pt" />
                                    <ComboBoxItem Content="ロシア語 (ru)" Tag="ru" />
                                </ComboBox>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="出力形式" Margin="0,8,0,6" />
                                <WrapPanel>
                                    <CheckBox x:Name="OutputTxtCheckBox" Content="txt" Margin="0,0,10,0" />
                                    <CheckBox x:Name="OutputSrtCheckBox" Content="srt" Margin="0,0,10,0" />
                                    <CheckBox x:Name="OutputVttCheckBox" Content="vtt" Margin="0,0,10,0" />
                                    <CheckBox x:Name="OutputJsonCheckBox" Content="json" Margin="0" />
                                </WrapPanel>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="自動実行時優先度" />
                                        <ComboBox x:Name="AutoPriorityComboBox"
                                                  Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=StackPanel}}"
                                                  SelectedValuePath="Tag">
                                            <ComboBoxItem Content="低" Tag="{x:Static domain:TranscriptionPriority.Low}" />
                                            <ComboBoxItem Content="通常" Tag="{x:Static domain:TranscriptionPriority.Normal}" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="手動実行時優先度" />
                                        <ComboBox x:Name="ManualPriorityComboBox"
                                                  Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=StackPanel}}"
                                                  SelectedValuePath="Tag">
                                            <ComboBoxItem Content="低" Tag="{x:Static domain:TranscriptionPriority.Low}" />
                                            <ComboBoxItem Content="通常" Tag="{x:Static domain:TranscriptionPriority.Normal}" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="モデル保存先" Margin="0,8,0,6" />
                                <TextBox x:Name="ModelDirectoryTextBox" IsReadOnly="True" />
                                <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMuted}" Text="文字起こし結果は録音ファイルと同じフォルダへ同名で出力されます。" />

                                <WrapPanel Margin="0,8,0,0">
                                    <Button x:Name="CheckEnvironmentButton" Content="環境チェック" Click="OnCheckEnvironmentClick" />
                                    <Button Content="モデル取得" Click="OnDownloadModelClick" />
                                    <Button Content="モデル削除" Click="OnDeleteModelClick" />
                                </WrapPanel>

                                <Border Margin="0,8,0,0" Background="#0E1724" BorderBrush="#2D3E55" BorderThickness="1" CornerRadius="6" Padding="8,6">
                                    <TextBlock x:Name="TranscriptionStatusTextBlock" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Width="100" Margin="0,0,8,0" Content="保存" Style="{StaticResource AccentButtonStyle}" IsDefault="True" Click="OnSaveClick" />
                        <Button Width="100" Content="キャンセル" IsCancel="True" />
                    </StackPanel>
                </Grid>
            </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>













