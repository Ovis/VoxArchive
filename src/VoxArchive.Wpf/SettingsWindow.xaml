<Window x:Class="VoxArchive.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定"
        Width="640"
        Height="250"
        MinWidth="640"
        MinHeight="250"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0A0D12"
        FontFamily="Yu Gothic UI">
    <Grid Margin="16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="#F3F6FA" Text="マイク遅延補正" />
        <TextBox x:Name="OffsetTextBox" Grid.Row="0" Grid.Column="1" Height="30" Margin="8,0,0,0" VerticalContentAlignment="Center" ToolTip="マイク音声を前後にずらしてスピーカー音声とタイミングを合わせます" />
        <TextBlock Grid.Row="0" Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#99A7BD" Text="ms" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,12,0,0" VerticalAlignment="Center" Foreground="#F3F6FA" Text="保存先" />
        <TextBox x:Name="OutputDirectoryTextBox" Grid.Row="1" Grid.Column="1" Margin="8,12,0,0" Height="30" VerticalContentAlignment="Center" />
        <Button Grid.Row="1" Grid.Column="2" Margin="8,12,0,0" Padding="10,4" Content="参照" Click="OnBrowseOutputDirectoryClick" />

        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10,0,0">
            <TextBlock Foreground="#99A7BD" Text="歌や会話の重なりが遅れて聞こえる場合に調整します。+で遅らせ、-で早めます。" TextWrapping="Wrap" />
            <TextBlock Margin="0,4,0,0" Foreground="#99A7BD" Text="補正値は -1000ms ～ 1000ms の範囲で指定してください。" />
        </StackPanel>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="90" Margin="0,0,8,0" Content="キャンセル" IsCancel="True" />
            <Button Width="90" Content="保存" IsDefault="True" Click="OnSaveClick" />
        </StackPanel>
    </Grid>
</Window>
