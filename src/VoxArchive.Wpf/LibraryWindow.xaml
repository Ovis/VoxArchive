<Window x:Class="VoxArchive.Wpf.LibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ライブラリ"
        Width="1320"
        Height="780"
        MinWidth="1180"
        MinHeight="700"
        WindowStyle="None"
        ResizeMode="CanResize"
        FontFamily="Yu Gothic UI"
        Background="#0B1018">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBg" Color="#0B1018" />
        <SolidColorBrush x:Key="CardBg" Color="#121B27" />
        <SolidColorBrush x:Key="CardBorder" Color="#243244" />
        <SolidColorBrush x:Key="ControlBg" Color="#1A2636" />
        <SolidColorBrush x:Key="ControlBgHover" Color="#223246" />
        <SolidColorBrush x:Key="ControlBorder" Color="#35506E" />
        <SolidColorBrush x:Key="TextPrimary" Color="#EFF4FC" />
        <SolidColorBrush x:Key="TextMuted" Color="#95A7C0" />
        <SolidColorBrush x:Key="Accent" Color="#3B82F6" />
        <SolidColorBrush x:Key="AccentHover" Color="#5B9BFF" />
        <SolidColorBrush x:Key="Danger" Color="#B53A48" />
        <SolidColorBrush x:Key="DangerHover" Color="#CD4B5A" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2A5EBD" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="#1B2A3C" />
            <Setter Property="BorderBrush" Value="#2F4664" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Base"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Base" Property="Background" Value="#24364C" />
                                <Setter TargetName="Base" Property="BorderBrush" Value="#3A5678" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Base" Property="Background" Value="#172434" />
                                <Setter TargetName="Base" Property="BorderBrush" Value="#2A405B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6F7E94" />
                                <Setter TargetName="Base" Property="Background" Value="#162131" />
                                <Setter TargetName="Base" Property="BorderBrush" Value="#25364C" />
                                <Setter TargetName="Base" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Background" Value="#2F6FD8" />
            <Setter Property="BorderBrush" Value="#3C7BE2" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Background" Value="#9F3742" />
            <Setter Property="BorderBrush" Value="#B14551" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="GridCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource CommonGridCheckBoxStyle}" />

        <Style x:Key="LabeledCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource CommonLabeledCheckBoxStyle}" />

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#7F8CA3" />
                    <Setter Property="Background" Value="#162131" />
                    <Setter Property="BorderBrush" Value="#25364C" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="#1B2A3C" />
            <Setter Property="Padding" Value="8,4" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#243A55" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A5EBD" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="#1B2A3C" />
            <Setter Property="BorderBrush" Value="#2F4664" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource LibraryComboBoxItemStyle}" />
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1B2A3C" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EFF4FC" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A5EBD" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1B2A3C" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#EFF4FC" />
            </Style.Resources>
        </Style>

        <Style x:Key="SeekStepComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboRoot"
                                    Background="#1B2A3C"
                                    BorderBrush="#2F4664"
                                    BorderThickness="1"
                                    CornerRadius="6" />
                            <Grid Margin="8,0,8,0" IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding DataContext.SelectedSeekStepOption.Label, RelativeSource={RelativeSource TemplatedParent}}"
                                           Foreground="{StaticResource TextPrimary}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="▼"
                                           FontSize="10"
                                           Foreground="{StaticResource TextPrimary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Opacity="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#1B2A3C"
                                        BorderBrush="#2F4664"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer CanContentScroll="True" MaxHeight="260">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboRoot" Property="BorderBrush" Value="#3D5D84" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboRoot" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InlineLoadingProgressStyle" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Background" Value="#1A2636" />
            <Setter Property="BorderBrush" Value="#2F4664" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="8" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="LibraryScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#35506E" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Margin="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4B6B92" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Background" Value="#5B84B5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryScrollButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="#0E1724" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource LibraryScrollButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource LibraryScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource LibraryScrollButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto" />
                                <Setter Property="Height" Value="12" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="#131F2D" />
            <Setter Property="AlternatingRowBackground" Value="#162436" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#223246" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="34" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="#D7E3F5" />
            <Setter Property="Background" Value="#1B2A3F" />
            <Setter Property="BorderBrush" Value="#2D425F" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#131F2D" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A5EBD" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="LibraryContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="#182334" />
            <Setter Property="BorderBrush" Value="#2F4664" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="4">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#243A55" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#3D5D84" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#7F8CA3" />
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LibraryMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="2,4,2,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                HorizontalAlignment="Stretch"
                                Background="#2F4664" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarGlyphButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#3A4A60" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D9E2F0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Base"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Base" Property="Background" Value="#1D2A3A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Base" Property="Background" Value="#16202D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Base" Property="Background" Value="#121A26" />
                                <Setter TargetName="Base" Property="BorderBrush" Value="#273548" />
                                <Setter Property="Foreground" Value="#5F6D82" />
                                <Setter TargetName="Base" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#10161F"
                BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0"
                CornerRadius="10,10,0,0"
                MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
            <Grid Margin="10,0,6,0">
                <TextBlock Text="ライブラリ" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleBarGlyphButtonStyle}" Width="30"
                            Height="20"
                            Margin="0"
                            Padding="0"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Content="&#xE711;"
                            ToolTip="閉じる"
                            Background="Transparent"
                            BorderBrush="#3A4A60"
                            BorderThickness="1"
                            Click="OnTitleBarCloseButtonClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="ファイル追加" Command="{Binding AddFileCommand}" Style="{StaticResource FlatButtonStyle}" Margin="0" />
                <Button Grid.Column="2" Content="一覧一括削除" Command="{Binding RemoveCheckedFromListCommand}" Style="{StaticResource FlatButtonStyle}" Margin="0" />
                <Button Grid.Column="4" Content="ファイル一括削除" Command="{Binding DeleteCheckedFilesCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0" />
                <Button Grid.Column="6" Content="削除済ファイル一括削除" Command="{Binding RemoveMissingFromListCommand}" Style="{StaticResource FlatButtonStyle}" Margin="0" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.95*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <TextBlock Text="録音ファイル" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="ダブルクリックで再生/一時停止" Foreground="{StaticResource TextMuted}" Margin="12,2,0,0" DockPanel.Dock="Right" />
                    </DockPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              RowValidationErrorTemplate="{x:Null}"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              MouseDoubleClick="OnRecordingGridMouseDoubleClick"
                              PreviewMouseRightButtonDown="OnRecordingGridPreviewMouseRightButtonDown">
                        <DataGrid.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource LibraryScrollBarStyle}" />
                        </DataGrid.Resources>
                        <DataGrid.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" Style="{StaticResource LibraryContextMenuStyle}">
                                <MenuItem Header="Explorerで表示" Command="{Binding OpenInExplorerCommand}" Style="{StaticResource LibraryMenuItemStyle}" />
                                <MenuItem Header="文字起こし" Command="{Binding TranscribeCommand}" Style="{StaticResource LibraryMenuItemStyle}" />
                                <MenuItem Header="文字起こし結果を開く" Command="{Binding OpenTranscriptionFileCommand}" Style="{StaticResource LibraryMenuItemStyle}" />
                                <Separator Style="{StaticResource LibraryMenuSeparatorStyle}" />
                                <MenuItem Header="一覧から削除" Command="{Binding RemoveFromListCommand}" Style="{StaticResource LibraryMenuItemStyle}" />
                                <MenuItem Header="ファイル削除" Command="{Binding DeleteFileCommand}" Style="{StaticResource LibraryMenuItemStyle}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="44" CanUserSort="False" IsReadOnly="False">
                                <DataGridTemplateColumn.Header>
                                    <CheckBox IsChecked="{Binding DataContext.AllItemsChecked, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource GridCheckBoxStyle}" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource GridCheckBoxStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="タイトル" Binding="{Binding Title}" Width="2*" IsReadOnly="True" />
                            <DataGridTextColumn Header="ファイル名" Binding="{Binding FileName}" Width="2*" IsReadOnly="True" />
                            <DataGridTextColumn Header="長さ" Binding="{Binding DurationText}" Width="85" IsReadOnly="True" />
                            <DataGridTextColumn Header="更新日時" Binding="{Binding UpdatedText}" Width="165" IsReadOnly="True" />
                            <DataGridTextColumn Header="サイズ" Binding="{Binding SizeText}" Width="95" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Opacity" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Opacity" Value="0.45" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <TextBlock Grid.Row="0" Text="再生" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="{Binding PlaybackButtonText}" Command="{Binding TogglePlaybackCommand}" Width="116" Height="32" MinHeight="32" FontSize="12" Padding="10,5" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Content="停止" Command="{Binding StopCommand}" Width="78" Height="32" MinHeight="32" FontSize="12" Padding="10,5" Style="{StaticResource FlatButtonStyle}" Margin="0" />
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="{Binding PositionText}" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4" />
                    <Slider Grid.Row="3" Minimum="0" Maximum="{Binding DurationSeconds}" Value="{Binding SeekSeconds, Mode=TwoWay}" IsMoveToPointEnabled="True" PreviewMouseLeftButtonDown="OnSeekDragStart" PreviewMouseLeftButtonUp="OnSeekDragEnd" Margin="0,0,0,8" />
                    <Grid Grid.Row="4" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="38" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="38" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="58" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="－" Command="{Binding SeekBackwardCommand}" Height="30" MinHeight="30" FontSize="14" Padding="8,4" Style="{StaticResource FlatButtonStyle}" Margin="0" />
                        <ComboBox Grid.Column="2" Style="{StaticResource SeekStepComboBoxStyle}" Height="30" FontSize="12" ItemsSource="{Binding SeekStepOptions}" SelectedItem="{Binding SelectedSeekStepOption, Mode=TwoWay}" DisplayMemberPath="Label" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="4" Content="＋" Command="{Binding SeekForwardCommand}" Height="30" MinHeight="30" FontSize="14" Padding="8,4" Style="{StaticResource FlatButtonStyle}" Margin="0" />
                        <ComboBox Grid.Column="6" Style="{StaticResource SeekStepComboBoxStyle}" Height="30" FontSize="12" ItemsSource="{Binding PlaybackSpeedOptions}" SelectedItem="{Binding SelectedPlaybackSpeedOption, Mode=TwoWay}" DisplayMemberPath="Label" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="8" Content="等倍" Command="{Binding ResetPlaybackSpeedCommand}" Height="30" MinHeight="30" FontSize="12" Padding="8,4" Style="{StaticResource FlatButtonStyle}" Margin="0" />
                    </Grid>

                    <Grid Grid.Row="5" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="74" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Speaker Gain (dB)" Foreground="{StaticResource TextMuted}" />
                            <Slider Minimum="-60" Maximum="48" TickFrequency="3" IsSnapToTickEnabled="False" Value="{Binding SpeakerGainDb, Mode=TwoWay}" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="#1A2636" BorderBrush="#2D425F" BorderThickness="1" CornerRadius="8" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding SpeakerGainDb, StringFormat={}{0:F1}}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="6" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="74" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mic Gain (dB)" Foreground="{StaticResource TextMuted}" />
                            <Slider Minimum="-60" Maximum="48" TickFrequency="3" IsSnapToTickEnabled="False" Value="{Binding MicGainDb, Mode=TwoWay}" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="#1A2636" BorderBrush="#2D425F" BorderThickness="1" CornerRadius="8" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding MicGainDb, StringFormat={}{0:F1}}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="7" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="128" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" Content="ミックスしてモノラル再生" IsChecked="{Binding MixToMonoPlayback, Mode=TwoWay}" Style="{StaticResource LabeledCheckBoxStyle}" Margin="0,2,0,0" />
                        <Button Grid.Column="1" Content="モノラル保存" Command="{Binding SaveMonoMixCommand}" Style="{StaticResource FlatButtonStyle}" Margin="8,0,0,0" Height="30" MinHeight="30" FontSize="12" Padding="10,4" />
                    </Grid>

                    <StackPanel Grid.Row="9">
                        <TextBlock Text="編集" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />

                        <TextBlock Text="タイトル" Foreground="{StaticResource TextMuted}" />
                        <TextBox Text="{Binding EditableTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                        <Button Content="タイトル保存" Command="{Binding SaveTitleCommand}" Style="{StaticResource FlatButtonStyle}" Margin="0,0,0,8" />

                        <TextBlock Text="ファイル名" Foreground="{StaticResource TextMuted}" />
                        <TextBox Text="{Binding EditableFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                        <Button Content="リネーム" Command="{Binding RenameCommand}" Style="{StaticResource FlatButtonStyle}" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="文字起こし" Command="{Binding TranscribeCommand}" Style="{StaticResource FlatButtonStyle}" Margin="0,0,8,0" />
                            <Button Content="文字起こし結果を開く" Command="{Binding OpenTranscriptionFileCommand}" Style="{StaticResource FlatButtonStyle}" Margin="0" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTranscribing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ProgressBar Width="84" IsIndeterminate="True" Style="{StaticResource InlineLoadingProgressStyle}" />
                                <TextBlock Text="文字起こし中..."
                                           Margin="8,0,0,0"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>

                    <Border Grid.RowSpan="10" Background="#C0111823" CornerRadius="10" IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="録音ファイルを選択してください"
                                   Foreground="#C9D4E6"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Padding="10,6">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextMuted}" FontSize="12" TextTrimming="CharacterEllipsis" />
        </Border>
        </Grid>

    </Grid>
</Window>








