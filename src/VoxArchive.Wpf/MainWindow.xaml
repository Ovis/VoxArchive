<Window x:Class="VoxArchive.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoxArchive"
        Width="{Binding WindowWidth, Mode=OneWay}"
        Height="{Binding WindowHeight, Mode=OneWay}"
        MinWidth="{Binding WindowWidth, Mode=OneWay}"
        MinHeight="{Binding WindowHeight, Mode=OneWay}"
        ResizeMode="CanMinimize"
        Topmost="True"
        FontFamily="Yu Gothic UI"
        Background="#0A0D12">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#121821" />
        <SolidColorBrush x:Key="PanelBorder" Color="#283242" />
        <SolidColorBrush x:Key="ControlBg" Color="#1A2330" />
        <SolidColorBrush x:Key="ControlBorder" Color="#314055" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F3F6FA" />
        <SolidColorBrush x:Key="TextMuted" Color="#99A7BD" />
        <SolidColorBrush x:Key="Accent" Color="#E94545" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="RoundIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontWeight" Value="ExtraBold" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="#2A1010" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="28"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CircleIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="#1F2A38" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="28"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeviceIconButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleIconButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Button Style="{StaticResource RoundIconButtonStyle}"
                            Command="{Binding StartStopCommand}"
                            Visibility="{Binding RecordButtonVisibility}"
                            Content="REC" />

                    <StackPanel Orientation="Horizontal" Visibility="{Binding RecordingControlsVisibility}">
                        <Button Style="{StaticResource CircleIconButtonStyle}" Command="{Binding PauseResumeCommand}">
                            <Grid>
                                <Grid Visibility="{Binding PauseGlyphVisibility}" Width="24" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="9" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource TextPrimary}" CornerRadius="1" />
                                    <Border Grid.Column="2" Background="{StaticResource TextPrimary}" CornerRadius="1" />
                                </Grid>
                                <TextBlock Visibility="{Binding ResumeGlyphVisibility}"
                                           Text="&#xE768;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="18"
                                           Foreground="{StaticResource TextPrimary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource CircleIconButtonStyle}"
                                Margin="0"
                                Background="{StaticResource Accent}"
                                BorderBrush="{StaticResource Accent}"
                                Command="{Binding StartStopCommand}">
                            <Border Width="14"
                                    Height="14"
                                    Background="White"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Column="2"
                           Text="{Binding ElapsedText}"
                           FontFamily="Consolas"
                           FontSize="34"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />

                <Grid Grid.Column="4" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource DeviceIconButtonStyle}"
                            Command="{Binding ToggleSpeakerCaptureCommand}">
                        <Grid>
                            <TextBlock Text="&#xE767;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Foreground="{Binding SpeakerIconBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <Line X1="9" Y1="33" X2="33" Y2="9"
                                  Stroke="#FFDA5D5D"
                                  StrokeThickness="2.8"
                                  Visibility="{Binding SpeakerMuteSlashVisibility}" />
                        </Grid>
                    </Button>
                    <ComboBox Grid.Column="1"
                              Width="150"
                              Margin="0"
                              DisplayMemberPath="FriendlyName"
                              IsEnabled="{Binding IsDeviceSelectionEnabled}"
                              ItemsSource="{Binding SpeakerDevices}"
                              SelectedValuePath="DeviceId"
                              SelectedValue="{Binding SelectedSpeakerDeviceId, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Grid Grid.Column="6" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource DeviceIconButtonStyle}"
                            Command="{Binding ToggleMicCaptureCommand}">
                        <Grid>
                            <TextBlock Text="&#xE720;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Foreground="{Binding MicIconBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <Line X1="9" Y1="33" X2="33" Y2="9"
                                  Stroke="#FFDA5D5D"
                                  StrokeThickness="2.8"
                                  Visibility="{Binding MicMuteSlashVisibility}" />
                        </Grid>
                    </Button>
                    <ComboBox Grid.Column="1"
                              Width="150"
                              Margin="0"
                              DisplayMemberPath="FriendlyName"
                              IsEnabled="{Binding IsDeviceSelectionEnabled}"
                              ItemsSource="{Binding MicDevices}"
                              SelectedValuePath="DeviceId"
                              SelectedValue="{Binding SelectedMicDeviceId, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Button Grid.Column="8"
                        Padding="10,6"
                        Margin="10,0,0,0"
                        Content="{Binding MiniModeButtonText}"
                        Command="{Binding ToggleMiniModeCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                Padding="12,10"
                Visibility="{Binding DetailsVisibility}"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          Foreground="#111827"
                          Margin="6,0,12,0"
                          IsEnabled="{Binding IsDeviceSelectionEnabled}"
                          ItemsSource="{Binding OutputModes}"
                          SelectedItem="{Binding SelectedOutputMode, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="#111827" Text="{Binding}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Offset" />
                <TextBox Grid.Row="0" Grid.Column="3"
                         Margin="6,0,0,0"
                         IsEnabled="{Binding IsDeviceSelectionEnabled}"
                         Text="{Binding AlignmentMillisecondsText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="0" Grid.Column="4" Text="ms" Foreground="{StaticResource TextMuted}" />
                <TextBlock Grid.Row="0" Grid.Column="5" Margin="12,0,0,0" Text="{Binding OutputPathText}" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Text="Process" />
                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5"
                          Foreground="#111827"
                          Margin="6,10,8,0"
                          IsEnabled="{Binding IsProcessSelectionEnabled}"
                          ItemsSource="{Binding ProcessItems}"
                          SelectedItem="{Binding SelectedProcessItem, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="#111827" Text="{Binding DisplayText}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Row="1" Grid.Column="6"
                        Margin="0,10,0,0"
                        Padding="10,4"
                        Content="更新"
                        IsEnabled="{Binding IsProcessSelectionEnabled}"
                        Command="{Binding RefreshProcessesCommand}" />

                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Spk" />
                    <ProgressBar Grid.Column="1" Height="10" Maximum="100" Value="{Binding SpeakerLevelPercent, Mode=OneWay}" />
                    <TextBlock Grid.Column="2" Margin="12,0,0,0" Text="Mic" />
                    <ProgressBar Grid.Column="3" Height="10" Maximum="100" Value="{Binding MicLevelPercent, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,8,0,0"
                Padding="8,6"
                Visibility="{Binding DetailsVisibility}"
                Background="#10161F"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding MetricsText}" Foreground="{StaticResource TextMuted}" />
                <TextBlock Grid.Row="1" Margin="0,2,0,0" Text="{Binding LastErrorText}" Foreground="#FF8D8D" />
            </Grid>
        </Border>
    </Grid>
</Window>

