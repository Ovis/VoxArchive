<Window x:Class="VoxArchive.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VoxArchive.Wpf"
        Title="VoxArchive"
        Width="{Binding WindowWidth, Mode=OneWay}"
        Height="{Binding WindowHeight, Mode=OneWay}"
        MinWidth="{Binding WindowWidth, Mode=OneWay}"
        MinHeight="{Binding WindowHeight, Mode=OneWay}"
        ResizeMode="CanMinimize"
        Topmost="True"
        FontFamily="Yu Gothic UI"
        Background="#0A0D12">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#121821" />
        <SolidColorBrush x:Key="PanelBorder" Color="#283242" />
        <SolidColorBrush x:Key="ControlBg" Color="#1A2330" />
        <SolidColorBrush x:Key="ControlBorder" Color="#314055" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F3F6FA" />
        <SolidColorBrush x:Key="TextMuted" Color="#99A7BD" />
        <SolidColorBrush x:Key="Accent" Color="#E94545" />
        <local:LevelClipRectConverter x:Key="LevelClipRectConverter" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="RoundIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontWeight" Value="ExtraBold" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="#2A1010" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="28"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CircleIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="#1F2A38" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="28"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeviceIconButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleIconButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>

        <Style x:Key="MiniModeSwitchButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleIconButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="#223042" />
            <Setter Property="BorderBrush" Value="#3A4E69" />
        </Style>

        <Style x:Key="DeviceArrowToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#1A2330" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D6DCE7" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Base"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Base" Property="Background" Value="#223042" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Base" Property="Background" Value="#2A3A50" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Visibility="{Binding NormalHeaderVisibility}" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Button Style="{StaticResource RoundIconButtonStyle}" Command="{Binding StartStopCommand}" Visibility="{Binding RecordButtonVisibility}" Content="REC" />
                    <StackPanel Orientation="Horizontal" Visibility="{Binding RecordingControlsVisibility}">
                        <Button Style="{StaticResource CircleIconButtonStyle}" Command="{Binding PauseResumeCommand}">
                            <Grid>
                                <Grid Visibility="{Binding PauseGlyphVisibility}" Width="24" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="9" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource TextPrimary}" CornerRadius="1" />
                                    <Border Grid.Column="2" Background="{StaticResource TextPrimary}" CornerRadius="1" />
                                </Grid>
                                <TextBlock Visibility="{Binding ResumeGlyphVisibility}" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource CircleIconButtonStyle}" Margin="0" Background="{StaticResource Accent}" BorderBrush="{StaticResource Accent}" Command="{Binding StartStopCommand}">
                            <Border Width="14" Height="14" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Column="2" Text="{Binding ElapsedText}" FontFamily="Consolas" FontSize="34" FontWeight="Bold" VerticalAlignment="Center" />

                <Grid Grid.Column="4" x:Name="SpeakerDeviceAnchorNormal" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="22" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource DeviceIconButtonStyle}" Margin="0" ToolTip="{Binding SelectedSpeakerDeviceName}" Command="{Binding ToggleSpeakerCaptureCommand}">
                        <Grid>
                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{Binding SpeakerIconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#00BFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Clip>
                                        <RectangleGeometry>
                                            <RectangleGeometry.Rect>
                                                <MultiBinding Converter="{StaticResource LevelClipRectConverter}">
                                                    <Binding Path="SpeakerLevelPercent" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualHeight" />
                                                </MultiBinding>
                                            </RectangleGeometry.Rect>
                                        </RectangleGeometry>
                                    </TextBlock.Clip>
                                </TextBlock>
                            </Grid>
                            <Line X1="3" Y1="22" X2="21" Y2="4" Stroke="#FFDA5D5D" StrokeThickness="2.8" Visibility="{Binding SpeakerMuteSlashVisibility}" />
                        </Grid>
                    </Button>
                    <ToggleButton Grid.Column="1" Style="{StaticResource DeviceArrowToggleStyle}" Content="▼" ToolTip="{Binding SelectedSpeakerDeviceName}" IsChecked="{Binding IsSpeakerDevicePopupOpenNormal, Mode=TwoWay}" />
                    <Popup IsOpen="{Binding IsSpeakerDevicePopupOpenNormal, Mode=TwoWay}" PlacementTarget="{Binding ElementName=SpeakerDeviceAnchorNormal}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#64748B" BorderThickness="1" CornerRadius="6" MinWidth="260" Padding="4">
                            <ListBox ItemsSource="{Binding SpeakerDevices}" DisplayMemberPath="FriendlyName" SelectedValuePath="DeviceId" SelectedValue="{Binding SelectedSpeakerDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="White" Foreground="#111827" BorderThickness="0" />
                        </Border>
                    </Popup>
                </Grid>

                <Grid Grid.Column="6" x:Name="MicDeviceAnchorNormal" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="22" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource DeviceIconButtonStyle}" Margin="0" ToolTip="{Binding SelectedMicDeviceName}" Command="{Binding ToggleMicCaptureCommand}">
                        <Grid>
                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{Binding MicIconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#36E062" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Clip>
                                        <RectangleGeometry>
                                            <RectangleGeometry.Rect>
                                                <MultiBinding Converter="{StaticResource LevelClipRectConverter}" ConverterParameter="Vertical">
                                                    <Binding Path="MicLevelPercent" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualHeight" />
                                                </MultiBinding>
                                            </RectangleGeometry.Rect>
                                        </RectangleGeometry>
                                    </TextBlock.Clip>
                                </TextBlock>
                            </Grid>
                            <Line X1="3" Y1="22" X2="21" Y2="4" Stroke="#FFDA5D5D" StrokeThickness="2.8" Visibility="{Binding MicMuteSlashVisibility}" />
                        </Grid>
                    </Button>
                    <ToggleButton Grid.Column="1" Style="{StaticResource DeviceArrowToggleStyle}" Content="▼" ToolTip="{Binding SelectedMicDeviceName}" IsChecked="{Binding IsMicDevicePopupOpenNormal, Mode=TwoWay}" />
                    <Popup IsOpen="{Binding IsMicDevicePopupOpenNormal, Mode=TwoWay}" PlacementTarget="{Binding ElementName=MicDeviceAnchorNormal}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#64748B" BorderThickness="1" CornerRadius="6" MinWidth="260" Padding="4">
                            <ListBox ItemsSource="{Binding MicDevices}" DisplayMemberPath="FriendlyName" SelectedValuePath="DeviceId" SelectedValue="{Binding SelectedMicDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="White" Foreground="#111827" BorderThickness="0" />
                        </Border>
                    </Popup>
                </Grid>

                <Button Grid.Column="8" Style="{StaticResource MiniModeSwitchButtonStyle}" ToolTip="{Binding MiniModeButtonText}" Command="{Binding ToggleMiniModeCommand}"><TextBlock Text="{Binding MiniModeGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
            </Grid>
        </Border>

        <Border Grid.Row="0" Visibility="{Binding MiniHeaderVisibility}" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Button Style="{StaticResource RoundIconButtonStyle}" Command="{Binding StartStopCommand}" Visibility="{Binding RecordButtonVisibility}" Content="REC" />
                    <StackPanel Orientation="Horizontal" Visibility="{Binding RecordingControlsVisibility}">
                        <Button Style="{StaticResource CircleIconButtonStyle}" Command="{Binding PauseResumeCommand}">
                            <Grid>
                                <Grid Visibility="{Binding PauseGlyphVisibility}" Width="24" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="9" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource TextPrimary}" CornerRadius="1" />
                                    <Border Grid.Column="2" Background="{StaticResource TextPrimary}" CornerRadius="1" />
                                </Grid>
                                <TextBlock Visibility="{Binding ResumeGlyphVisibility}" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource CircleIconButtonStyle}" Margin="0" Background="{StaticResource Accent}" BorderBrush="{StaticResource Accent}" Command="{Binding StartStopCommand}">
                            <Border Width="14" Height="14" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Column="2" Text="{Binding ElapsedText}" FontFamily="Consolas" FontSize="30" FontWeight="Bold" VerticalAlignment="Center" />

                <Grid Grid.Column="4" x:Name="SpeakerDeviceAnchorMini" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="22" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource DeviceIconButtonStyle}" Margin="0" ToolTip="{Binding SelectedSpeakerDeviceName}" Command="{Binding ToggleSpeakerCaptureCommand}">
                        <Grid>
                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{Binding SpeakerIconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#00BFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Clip>
                                        <RectangleGeometry>
                                            <RectangleGeometry.Rect>
                                                <MultiBinding Converter="{StaticResource LevelClipRectConverter}">
                                                    <Binding Path="SpeakerLevelPercent" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualHeight" />
                                                </MultiBinding>
                                            </RectangleGeometry.Rect>
                                        </RectangleGeometry>
                                    </TextBlock.Clip>
                                </TextBlock>
                            </Grid>
                            <Line X1="3" Y1="22" X2="21" Y2="4" Stroke="#FFDA5D5D" StrokeThickness="2.8" Visibility="{Binding SpeakerMuteSlashVisibility}" />
                        </Grid>
                    </Button>
                    <ToggleButton Grid.Column="1" Style="{StaticResource DeviceArrowToggleStyle}" Content="▼" ToolTip="{Binding SelectedSpeakerDeviceName}" IsChecked="{Binding IsSpeakerDevicePopupOpenMini, Mode=TwoWay}" />
                    <Popup IsOpen="{Binding IsSpeakerDevicePopupOpenMini, Mode=TwoWay}" PlacementTarget="{Binding ElementName=SpeakerDeviceAnchorMini}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#64748B" BorderThickness="1" CornerRadius="6" MinWidth="260" Padding="4">
                            <ListBox ItemsSource="{Binding SpeakerDevices}" DisplayMemberPath="FriendlyName" SelectedValuePath="DeviceId" SelectedValue="{Binding SelectedSpeakerDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="White" Foreground="#111827" BorderThickness="0" />
                        </Border>
                    </Popup>
                </Grid>

                <Grid Grid.Column="6" x:Name="MicDeviceAnchorMini" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="22" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource DeviceIconButtonStyle}" Margin="0" ToolTip="{Binding SelectedMicDeviceName}" Command="{Binding ToggleMicCaptureCommand}">
                        <Grid>
                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{Binding MicIconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#36E062" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Clip>
                                        <RectangleGeometry>
                                            <RectangleGeometry.Rect>
                                                <MultiBinding Converter="{StaticResource LevelClipRectConverter}" ConverterParameter="Vertical">
                                                    <Binding Path="MicLevelPercent" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualHeight" />
                                                </MultiBinding>
                                            </RectangleGeometry.Rect>
                                        </RectangleGeometry>
                                    </TextBlock.Clip>
                                </TextBlock>
                            </Grid>
                            <Line X1="3" Y1="22" X2="21" Y2="4" Stroke="#FFDA5D5D" StrokeThickness="2.8" Visibility="{Binding MicMuteSlashVisibility}" />
                        </Grid>
                    </Button>
                    <ToggleButton Grid.Column="1" Style="{StaticResource DeviceArrowToggleStyle}" Content="▼" ToolTip="{Binding SelectedMicDeviceName}" IsChecked="{Binding IsMicDevicePopupOpenMini, Mode=TwoWay}" />
                    <Popup IsOpen="{Binding IsMicDevicePopupOpenMini, Mode=TwoWay}" PlacementTarget="{Binding ElementName=MicDeviceAnchorMini}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#64748B" BorderThickness="1" CornerRadius="6" MinWidth="260" Padding="4">
                            <ListBox ItemsSource="{Binding MicDevices}" DisplayMemberPath="FriendlyName" SelectedValuePath="DeviceId" SelectedValue="{Binding SelectedMicDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="White" Foreground="#111827" BorderThickness="0" />
                        </Border>
                    </Popup>
                </Grid>

                <Button Grid.Column="8" Style="{StaticResource MiniModeSwitchButtonStyle}" Margin="0" ToolTip="{Binding MiniModeButtonText}" Command="{Binding ToggleMiniModeCommand}"><TextBlock Text="{Binding MiniModeGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,0" Padding="12,10" Visibility="{Binding DetailsVisibility}" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode" />
                <ComboBox Grid.Row="0" Grid.Column="1" Foreground="#111827" Margin="6,0,12,0" IsEnabled="{Binding IsDeviceSelectionEnabled}" ItemsSource="{Binding OutputModes}" SelectedItem="{Binding SelectedOutputMode, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Foreground="#111827" Text="{Binding}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Offset" />
                <TextBox Grid.Row="0" Grid.Column="3" Margin="6,0,0,0" IsEnabled="{Binding IsDeviceSelectionEnabled}" Text="{Binding AlignmentMillisecondsText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="0" Grid.Column="4" Text="ms" Foreground="{StaticResource TextMuted}" />
                <TextBlock Grid.Row="0" Grid.Column="5" Margin="12,0,0,0" Text="{Binding OutputPathText}" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Text="Process" />
                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5" Foreground="#111827" Margin="6,10,8,0" IsEnabled="{Binding IsProcessSelectionEnabled}" ItemsSource="{Binding ProcessItems}" SelectedItem="{Binding SelectedProcessItem, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Foreground="#111827" Text="{Binding DisplayText}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Row="1" Grid.Column="6" Margin="0,10,0,0" Padding="10,4" Content="更新" IsEnabled="{Binding IsProcessSelectionEnabled}" Command="{Binding RefreshProcessesCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="0,8,0,0" Padding="8,6" Visibility="{Binding DetailsVisibility}" Background="#10161F" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding MetricsText}" Foreground="{StaticResource TextMuted}" />
                <TextBlock Grid.Row="1" Margin="0,2,0,0" Text="{Binding LastErrorText}" Foreground="#FF8D8D" />
            </Grid>
        </Border>
    </Grid>
</Window>

