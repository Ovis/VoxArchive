<Window x:Class="VoxArchive.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoxArchive"
        Width="{Binding WindowWidth, Mode=OneWay}"
        Height="{Binding WindowHeight, Mode=OneWay}"
        MinWidth="{Binding WindowWidth, Mode=OneWay}"
        MinHeight="{Binding WindowHeight, Mode=OneWay}"
        ResizeMode="CanMinimize"
        Topmost="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" MinWidth="96" Margin="0,0,8,0" Padding="14,6" Content="{Binding StartStopButtonText}" Command="{Binding StartStopCommand}" />
            <Button Grid.Column="1" MinWidth="96" Margin="0,0,8,0" Padding="14,6" Content="{Binding PauseResumeButtonText}" Command="{Binding PauseResumeCommand}" />

            <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="{Binding ElapsedText}" />
            <TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="14" Text="{Binding StateText}" />
            <Button Grid.Column="5" Padding="10,6" Content="{Binding MiniModeButtonText}" Command="{Binding ToggleMiniModeCommand}" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,8,0,0" Visibility="{Binding DetailsVisibility}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Speaker" />
            <ComboBox Grid.Column="1" Margin="4,0,8,0" DisplayMemberPath="FriendlyName" IsEnabled="{Binding IsDeviceSelectionEnabled}" ItemsSource="{Binding SpeakerDevices}" SelectedValuePath="DeviceId" SelectedValue="{Binding SelectedSpeakerDeviceId, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Mic" />
            <ComboBox Grid.Column="3" Margin="4,0,8,0" DisplayMemberPath="FriendlyName" IsEnabled="{Binding IsDeviceSelectionEnabled}" ItemsSource="{Binding MicDevices}" SelectedValuePath="DeviceId" SelectedValue="{Binding SelectedMicDeviceId, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="Mode" />
            <ComboBox Grid.Column="5" Margin="4,0,0,0" IsEnabled="{Binding IsDeviceSelectionEnabled}" ItemsSource="{Binding OutputModes}" SelectedItem="{Binding SelectedOutputMode, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,8,0,0" Visibility="{Binding DetailsVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Spk Level" />
                <ProgressBar Grid.Column="1" Height="10" Maximum="100" Value="{Binding SpeakerLevelPercent, Mode=OneWay}" />
                <TextBlock Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" Text="Mic Level" />
                <ProgressBar Grid.Column="3" Height="10" Maximum="100" Value="{Binding MicLevelPercent, Mode=OneWay}" />

                <TextBlock Grid.Column="4" Margin="12,0,0,0" VerticalAlignment="Center" Text="Process" />
                <ComboBox Grid.Column="5"
                          Margin="4,0,6,0"
                          DisplayMemberPath="DisplayText"
                          IsEnabled="{Binding IsProcessSelectionEnabled}"
                          ItemsSource="{Binding ProcessItems}"
                          SelectedItem="{Binding SelectedProcessItem, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="6"
                        Padding="8,4"
                        Content="更新"
                        IsEnabled="{Binding IsProcessSelectionEnabled}"
                        Command="{Binding RefreshProcessesCommand}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Offset(ms)" />
                <TextBox Grid.Column="1"
                         Margin="6,0,0,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding AlignmentMillisecondsText, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsDeviceSelectionEnabled}" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding OutputPathText}" />
            </Grid>

            <TextBlock Grid.Row="2" Margin="0,2,0,0" Text="{Binding MetricsText}" />
            <TextBlock Grid.Row="3" Margin="0,2,0,0" Foreground="DarkRed" Text="{Binding LastErrorText}" />
        </Grid>
    </Grid>
</Window>
