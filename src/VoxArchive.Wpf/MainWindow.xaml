<Window x:Class="VoxArchive.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VoxArchive.Wpf"
        Title="VoxArchive"
        Width="{Binding WindowWidth, Mode=OneWay}"
        Height="{Binding WindowHeight, Mode=OneWay}"
        MinWidth="{Binding WindowWidth, Mode=OneWay}"
        MinHeight="{Binding WindowHeight, Mode=OneWay}"
        ResizeMode="NoResize"
        WindowStyle="None"
        Topmost="True"
        FontFamily="Yu Gothic UI"
        Background="#121821">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#121821" />
        <SolidColorBrush x:Key="PanelBorder" Color="#1A2330" />
        <SolidColorBrush x:Key="ControlBg" Color="#1A2330" />
        <SolidColorBrush x:Key="ControlBorder" Color="#314055" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F3F6FA" />
        <SolidColorBrush x:Key="TextMuted" Color="#99A7BD" />
        <SolidColorBrush x:Key="Accent" Color="#E94545" />
        <local:LevelClipRectConverter x:Key="LevelClipRectConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="RoundIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontWeight" Value="ExtraBold" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="#2A1010" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="28"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CircleIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="#1F2A38" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="28"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeviceIconButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleIconButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleIconButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="#223042" />
            <Setter Property="BorderBrush" Value="#3A4E69" />
        </Style>

        <Style x:Key="DeviceArrowToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#1A2330" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D6DCE7" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Base"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Base" Property="Background" Value="#223042" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Base" Property="Background" Value="#2A3A50" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Base" Property="Background" Value="#161E2A" />
                                <Setter TargetName="Base" Property="BorderBrush" Value="#2A3445" />
                                <Setter Property="Foreground" Value="#5F6D82" />
                                <Setter TargetName="Base" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopupListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="PopupListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#10161F"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0"
                CornerRadius="10,10,0,0"
                MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
            <Grid Margin="10,0,6,0">
                <TextBlock Text="VoxArchive" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Width="24"
                            Height="20"
                            Margin="0,0,6,0"
                            Padding="0"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="11"
                            Content="&#xE8B7;"
                            ToolTip="ライブラリ"
                            Background="Transparent"
                            BorderBrush="#3A4A60"
                            BorderThickness="1"
                            Command="{Binding OpenLibraryCommand}" />
                    <Button Width="24"
                            Height="20"
                            Margin="0,0,6,0"
                            Padding="0"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="11"
                            Content="&#xE713;"
                            ToolTip="設定"
                            Background="Transparent"
                            BorderBrush="#3A4A60"
                            BorderThickness="1"
                            Command="{Binding OpenSettingsCommand}" />
                    <Button Width="30"
                            Height="20"
                            Margin="0"
                            Padding="0"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Content="&#xE711;"
                            ToolTip="閉じる"
                            Background="Transparent"
                            BorderBrush="#3A4A60"
                            BorderThickness="1"
                            Click="OnTitleBarCloseButtonClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#121821" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0" CornerRadius="0,0,10,10" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Button Style="{StaticResource RoundIconButtonStyle}" Command="{Binding StartStopCommand}" Visibility="{Binding RecordButtonVisibility}" Content="REC" />
                    <StackPanel Orientation="Horizontal" Visibility="{Binding RecordingControlsVisibility}">
                        <Button Style="{StaticResource CircleIconButtonStyle}" Command="{Binding PauseResumeCommand}">
                            <Grid>
                                <Grid Visibility="{Binding PauseGlyphVisibility}" Width="24" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="9" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource TextPrimary}" CornerRadius="1" />
                                    <Border Grid.Column="2" Background="{StaticResource TextPrimary}" CornerRadius="1" />
                                </Grid>
                                <TextBlock Visibility="{Binding ResumeGlyphVisibility}" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource CircleIconButtonStyle}" Margin="0" Background="{StaticResource Accent}" BorderBrush="{StaticResource Accent}" Command="{Binding StartStopCommand}">
                            <Border Width="14" Height="14" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Column="2" Text="{Binding ElapsedText}" FontFamily="Consolas" FontSize="34" FontWeight="Bold" VerticalAlignment="Center" />

                <Grid Grid.Column="4" x:Name="SpeakerDeviceAnchorNormal" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="22" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource DeviceIconButtonStyle}" Margin="0" ToolTip="{Binding SelectedSpeakerDeviceName}" Command="{Binding ToggleSpeakerCaptureCommand}">
                        <Grid>
                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{Binding SpeakerIconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#00BFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Clip>
                                        <RectangleGeometry>
                                            <RectangleGeometry.Rect>
                                                <MultiBinding Converter="{StaticResource LevelClipRectConverter}">
                                                    <Binding Path="SpeakerLevelPercent" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualHeight" />
                                                </MultiBinding>
                                            </RectangleGeometry.Rect>
                                        </RectangleGeometry>
                                    </TextBlock.Clip>
                                </TextBlock>
                            </Grid>
                            <Line X1="3" Y1="22" X2="21" Y2="4" Stroke="#FFDA5D5D" StrokeThickness="2.8" Visibility="{Binding SpeakerMuteSlashVisibility}" />
                        </Grid>
                    </Button>
                    <ToggleButton Grid.Column="1" Style="{StaticResource DeviceArrowToggleStyle}" Content="▼" ToolTip="{Binding SelectedSpeakerDeviceName}" IsChecked="{Binding IsSpeakerDevicePopupOpenNormal, Mode=TwoWay}" />
                    <Popup IsOpen="{Binding IsSpeakerDevicePopupOpenNormal, Mode=TwoWay}" PlacementTarget="{Binding ElementName=SpeakerDeviceAnchorNormal}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#64748B" BorderThickness="1" CornerRadius="6" MinWidth="260" Padding="4">
                            <ListBox ItemsSource="{Binding SpeakerDevices}" DisplayMemberPath="FriendlyName" SelectedValuePath="DeviceId" SelectedValue="{Binding SelectedSpeakerDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PopupListBoxStyle}" ItemContainerStyle="{StaticResource PopupListBoxItemStyle}" PreviewMouseLeftButtonUp="OnDeviceListBoxPreviewMouseLeftButtonUp" />
                        </Border>
                    </Popup>
                </Grid>

                <Grid Grid.Column="6" x:Name="MicDeviceAnchorNormal" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="22" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource DeviceIconButtonStyle}" Margin="0" ToolTip="{Binding SelectedMicDeviceName}" Command="{Binding ToggleMicCaptureCommand}">
                        <Grid>
                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{Binding MicIconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#36E062" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Clip>
                                        <RectangleGeometry>
                                            <RectangleGeometry.Rect>
                                                <MultiBinding Converter="{StaticResource LevelClipRectConverter}" ConverterParameter="Vertical">
                                                    <Binding Path="MicLevelPercent" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualHeight" />
                                                </MultiBinding>
                                            </RectangleGeometry.Rect>
                                        </RectangleGeometry>
                                    </TextBlock.Clip>
                                </TextBlock>
                            </Grid>
                            <Line X1="3" Y1="22" X2="21" Y2="4" Stroke="#FFDA5D5D" StrokeThickness="2.8" Visibility="{Binding MicMuteSlashVisibility}" />
                        </Grid>
                    </Button>
                    <ToggleButton Grid.Column="1" Style="{StaticResource DeviceArrowToggleStyle}" Content="▼" ToolTip="{Binding SelectedMicDeviceName}" IsChecked="{Binding IsMicDevicePopupOpenNormal, Mode=TwoWay}" />
                    <Popup IsOpen="{Binding IsMicDevicePopupOpenNormal, Mode=TwoWay}" PlacementTarget="{Binding ElementName=MicDeviceAnchorNormal}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#64748B" BorderThickness="1" CornerRadius="6" MinWidth="260" Padding="4">
                            <ListBox ItemsSource="{Binding MicDevices}" DisplayMemberPath="FriendlyName" SelectedValuePath="DeviceId" SelectedValue="{Binding SelectedMicDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PopupListBoxStyle}" ItemContainerStyle="{StaticResource PopupListBoxItemStyle}" PreviewMouseLeftButtonUp="OnDeviceListBoxPreviewMouseLeftButtonUp" />
                        </Border>
                    </Popup>
                </Grid>

                <Grid Grid.Column="7" x:Name="ModeProcessAnchorNormal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="22" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource DeviceIconButtonStyle}" Margin="0" ToolTip="{Binding SelectedOutputModeName}" Command="{Binding ToggleOutputModeCommand}" IsEnabled="{Binding IsDeviceSelectionEnabled}">
                        <Grid Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Visibility="{Binding IsSpeakerMode, Converter={StaticResource BoolToVisibilityConverter}}" Fill="{StaticResource TextPrimary}" Data="M3,7 H7 L13,3 V17 L7,13 H3 Z" Stretch="Fill" />
                            <Path Visibility="{Binding IsProgramMode, Converter={StaticResource BoolToVisibilityConverter}}" Stroke="{StaticResource TextPrimary}" StrokeThickness="1.8" Data="M2,3 H18 V17 H2 Z M2,6 H18" Stretch="Fill" />
                        </Grid>
                    </Button>
                    <ToggleButton Grid.Column="1" Style="{StaticResource DeviceArrowToggleStyle}" Content="▼" ToolTip="{Binding SelectedProcessDisplayName}" IsChecked="{Binding IsProcessPopupOpenNormal, Mode=TwoWay}" IsEnabled="{Binding IsProcessSelectionEnabled}" />
                    <Popup IsOpen="{Binding IsProcessPopupOpenNormal, Mode=TwoWay}" PlacementTarget="{Binding ElementName=ModeProcessAnchorNormal}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#64748B" BorderThickness="1" CornerRadius="6" MinWidth="320" Padding="4">
                            <StackPanel>
                                <Button Margin="0,0,0,4" Padding="8,3" Content="更新" Command="{Binding RefreshProcessesCommand}" IsEnabled="{Binding IsProcessSelectionEnabled}" Foreground="#111827" Background="#E5E7EB" BorderBrush="#CBD5E1" />
                                <ListBox ItemsSource="{Binding ProcessItems}" DisplayMemberPath="DisplayText" SelectedItem="{Binding SelectedProcessItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PopupListBoxStyle}" ItemContainerStyle="{StaticResource PopupListBoxItemStyle}" Width="360" MaxHeight="260" ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

