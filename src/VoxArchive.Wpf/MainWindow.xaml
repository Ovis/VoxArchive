<Window x:Class="VoxArchive.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoxArchive"
        Width="{Binding WindowWidth, Mode=OneWay}"
        Height="{Binding WindowHeight, Mode=OneWay}"
        MinWidth="{Binding WindowWidth, Mode=OneWay}"
        MinHeight="{Binding WindowHeight, Mode=OneWay}"
        ResizeMode="CanMinimize"
        Topmost="True"
        FontFamily="Yu Gothic UI"
        Background="#0A0D12">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#121821" />
        <SolidColorBrush x:Key="PanelBorder" Color="#283242" />
        <SolidColorBrush x:Key="ControlBg" Color="#1A2330" />
        <SolidColorBrush x:Key="ControlBorder" Color="#314055" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F3F6FA" />
        <SolidColorBrush x:Key="TextMuted" Color="#99A7BD" />
        <SolidColorBrush x:Key="Accent" Color="#E94545" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="RoundIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="#2A1010" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
        </Style>

        <Style x:Key="SquareIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Button Style="{StaticResource RoundIconButtonStyle}"
                            Command="{Binding StartStopCommand}"
                            Visibility="{Binding RecordButtonVisibility}"
                            Content="REC" />

                    <StackPanel Orientation="Horizontal" Visibility="{Binding RecordingControlsVisibility}">
                        <Button Style="{StaticResource SquareIconButtonStyle}" Command="{Binding PauseResumeCommand}">
                            <Grid>
                                <Grid Visibility="{Binding PauseGlyphVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="7" Height="20" Background="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Width="7" Height="20" Background="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                                <Path Visibility="{Binding ResumeGlyphVisibility}" Fill="{StaticResource TextPrimary}" Data="M 0 0 L 0 20 L 18 10 Z" Stretch="Uniform" Width="18" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource SquareIconButtonStyle}"
                                Margin="0"
                                Command="{Binding StartStopCommand}">
                            <Border Width="16" Height="16" Background="{StaticResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Column="2"
                           Text="{Binding ElapsedText}"
                           FontFamily="Consolas"
                           FontSize="34"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="4"
                           Text="{Binding StateText}"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="15"
                           VerticalAlignment="Center" />

                <Button Grid.Column="6"
                        Padding="10,6"
                        Margin="10,0,0,0"
                        Content="{Binding MiniModeButtonText}"
                        Command="{Binding ToggleMiniModeCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                Padding="12,10"
                Visibility="{Binding DetailsVisibility}"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="68" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Speaker" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          Margin="6,0,12,0"
                          DisplayMemberPath="FriendlyName"
                          IsEnabled="{Binding IsDeviceSelectionEnabled}"
                          ItemsSource="{Binding SpeakerDevices}"
                          SelectedValuePath="DeviceId"
                          SelectedValue="{Binding SelectedSpeakerDeviceId, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Mic" />
                <ComboBox Grid.Row="0" Grid.Column="3"
                          Margin="6,0,12,0"
                          DisplayMemberPath="FriendlyName"
                          IsEnabled="{Binding IsDeviceSelectionEnabled}"
                          ItemsSource="{Binding MicDevices}"
                          SelectedValuePath="DeviceId"
                          SelectedValue="{Binding SelectedMicDeviceId, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Mode" />
                <ComboBox Grid.Row="0" Grid.Column="5"
                          Margin="6,0,12,0"
                          IsEnabled="{Binding IsDeviceSelectionEnabled}"
                          ItemsSource="{Binding OutputModes}"
                          SelectedItem="{Binding SelectedOutputMode, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="0" Grid.Column="6" Text="Offset" />
                <TextBox Grid.Row="0" Grid.Column="7"
                         Margin="6,0,8,0"
                         IsEnabled="{Binding IsDeviceSelectionEnabled}"
                         Text="{Binding AlignmentMillisecondsText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="0" Grid.Column="8" Text="ms" Foreground="{StaticResource TextMuted}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Text="Process" />
                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="7"
                          Margin="6,10,8,0"
                          DisplayMemberPath="DisplayText"
                          IsEnabled="{Binding IsProcessSelectionEnabled}"
                          ItemsSource="{Binding ProcessItems}"
                          SelectedItem="{Binding SelectedProcessItem, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="1" Grid.Column="8"
                        Margin="0,10,0,0"
                        Padding="10,4"
                        Content="更新"
                        IsEnabled="{Binding IsProcessSelectionEnabled}"
                        Command="{Binding RefreshProcessesCommand}" />

                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="9" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Spk" />
                    <ProgressBar Grid.Column="1" Height="10" Maximum="100" Value="{Binding SpeakerLevelPercent, Mode=OneWay}" />
                    <TextBlock Grid.Column="2" Margin="12,0,0,0" Text="Mic" />
                    <ProgressBar Grid.Column="3" Height="10" Maximum="100" Value="{Binding MicLevelPercent, Mode=OneWay}" />
                    <TextBlock Grid.Column="4" Margin="16,0,0,0" Text="{Binding OutputPathText}" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,8,0,0"
                Padding="8,6"
                Visibility="{Binding DetailsVisibility}"
                Background="#10161F"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding MetricsText}" Foreground="{StaticResource TextMuted}" />
                <TextBlock Grid.Row="1" Margin="0,2,0,0" Text="{Binding LastErrorText}" Foreground="#FF8D8D" />
            </Grid>
        </Border>
    </Grid>
</Window>
